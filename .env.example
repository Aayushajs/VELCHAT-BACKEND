# ── VelChat dev environment ───────────────────────────────────────────────
# Copy to `.env`. NEVER commit real secrets — prod secrets come from Sealed Secrets / Vault.
# Validated at boot by @velchat/config (zod). Missing/invalid → service refuses to start.

NODE_ENV=development
LOG_LEVEL=debug
SERVICE_NAME=example-service
SERVICE_VERSION=0.1.0
HTTP_PORT=3000
GRPC_PORT=50051
METRICS_PORT=9464

# ── PostgreSQL (relational; RLS-enforced multi-tenant) ──
POSTGRES_URL=postgres://velchat:velchat@localhost:5432/velchat
POSTGRES_MAX_POOL=10

# ── MongoDB (chat documents; sharded-ready) ──
MONGO_URL=mongodb://velchat:velchat@localhost:27017/velchat?authSource=admin

# ── Valkey (cache / presence / seq counters) ──
VALKEY_URL=redis://localhost:6379

# ── Kafka (KRaft) ──
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=velchat
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8080/apis/registry/v2

# ── OpenSearch ──
OPENSEARCH_NODE=http://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=Velchat_dev_1!

# ── MinIO (S3) ──
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=velchatadmin
S3_SECRET_KEY=velchatadminsecret
S3_BUCKET=velchat-media

# ── OpenTelemetry ──
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACES_SAMPLER=parentbased_always_on

# ── Auth (placeholder; real keys via Sealed Secrets in prod) ──
JWT_ISSUER=https://auth.velchat.local
JWT_ACCESS_TTL_SECONDS=900
