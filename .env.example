# ── VelChat environment ──────────────────────────────────────────────────────
# Copy to `.env`. NEVER commit real secrets. Validated at boot by @velchat/config (zod, fail-closed).
#
# Two deployment profiles — flip the provider selectors, the app code is identical:
#   FREE-TIER (default): Neon + Atlas + Upstash + Cloudinary + Atlas Search + Grafana Cloud  (₹0)
#   SELF-HOST (scale):   Postgres + Mongo + Valkey + Kafka + MinIO + OpenSearch (docker-compose / K8s)

NODE_ENV=development
LOG_LEVEL=debug
SERVICE_NAME=example-service
# SERVICE_VERSION is auto-stamped from package.json + git short SHA (libs/config). Uncomment to pin (CI).
# SERVICE_VERSION=0.1.0
HTTP_PORT=3000
GRPC_PORT=50051
METRICS_PORT=9464

# ── Provider selection ──
EVENT_BUS=redis-streams          # redis-streams (Upstash, free) | kafka (self-host)
STORAGE_PROVIDER=cloudinary      # cloudinary (free) | s3 (MinIO/AWS)
SEARCH_PROVIDER=atlas            # atlas (Atlas Search, free) | opensearch (self-host)

# ── PostgreSQL → Neon (free) | local docker-compose ──
POSTGRES_URL=postgres://velchat:velchat@localhost:5432/velchat
POSTGRES_MAX_POOL=10

# ── MongoDB → Atlas (free) | local docker-compose. Also backs SEARCH_PROVIDER=atlas ──
MONGO_URL=mongodb://velchat:velchat@localhost:27017/velchat?authSource=admin

# ── Redis → Upstash (free, rediss://) | local Valkey. Cache + Redis Streams event bus ──
VALKEY_URL=redis://localhost:6379

# ── Media → Cloudinary (free). Required when STORAGE_PROVIDER=cloudinary ──
CLOUDINARY_URL=

# ── OpenTelemetry → Grafana Cloud (free) | local Tempo ──
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64 instanceID:token>   # Grafana Cloud

# ── Self-host only (EVENT_BUS=kafka) ──
# KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=velchat

# ── Self-host only (SEARCH_PROVIDER=opensearch) ──
# OPENSEARCH_NODE=http://localhost:9200
# OPENSEARCH_USERNAME=admin
# OPENSEARCH_PASSWORD=Velchat_dev_1!

# ── Self-host only (STORAGE_PROVIDER=s3 / MinIO) ──
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_ACCESS_KEY=velchatadmin
# S3_SECRET_KEY=velchatadminsecret
# S3_BUCKET=velchat-media

# ── Auth (placeholder; real keys via secrets manager in prod) ──
JWT_ISSUER=https://auth.velchat.local
JWT_ACCESS_TTL_SECONDS=900
