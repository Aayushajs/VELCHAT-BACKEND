{
  "name": "@velchat/auth-service",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "jest",
    "test:int": "jest -c jest.int.config.cjs --runInBand",
    "start": "cross-env SERVICE_NAME=auth-service HTTP_PORT=3002 node dist/main.js",
    "dev": "cross-env SERVICE_NAME=auth-service HTTP_PORT=3002 tsx watch src/main.ts",
    "clean": "rimraf dist .turbo coverage"
  },
  "dependencies": {
    "@nestjs/axios": "^3.1.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@simplewebauthn/server": "^11.0.0",
    "@velchat/cache": "workspace:*",
    "@velchat/config": "workspace:*",
    "@velchat/database": "workspace:*",
    "@velchat/event-bus": "workspace:*",
    "@velchat/mail": "workspace:*",
    "@velchat/shared-types": "workspace:*",
    "@velchat/shared-utils": "workspace:*",
    "axios": "^1.7.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "drizzle-orm": "^0.38.3",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "otplib": "^12.0.1",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.5",
    "testcontainers": "^10.13.2"
  }
}
