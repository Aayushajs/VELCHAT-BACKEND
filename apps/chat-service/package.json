{
  "name": "@velchat/chat-service",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "jest",
    "start": "cross-env SERVICE_NAME=chat-service HTTP_PORT=3004 node dist/main.js",
    "dev": "cross-env SERVICE_NAME=chat-service HTTP_PORT=3004 tsx watch src/main.ts",
    "clean": "rimraf dist .turbo coverage"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@velchat/config": "workspace:*",
    "@velchat/event-bus": "workspace:*",
    "@velchat/shared-types": "workspace:*",
    "@velchat/shared-utils": "workspace:*",
    "ioredis": "^5.4.2",
    "mongoose": "^8.9.3",
    "pino": "^9.6.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  }
}
