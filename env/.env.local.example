# ── VelChat — LOCAL dev (self-hosted via docker/compose.yml) ──────────────────
# Copy to repo-root `.env`:  cp env/.env.local.example .env  &&  pnpm infra:up
# Validated at boot by @velchat/config (zod, fail-closed). Loaded via dotenv.

NODE_ENV=development
LOG_LEVEL=debug
SERVICE_NAME=example-service   # per-service start scripts override this (cross-env)
# SERVICE_VERSION is auto-stamped from package.json + git short SHA (libs/config). Uncomment to pin (CI).
# SERVICE_VERSION=0.1.0
HTTP_PORT=3000
GRPC_PORT=50051
METRICS_PORT=9464

# ── Provider selection → everything self-hosted (pnpm infra:up) ──
EVENT_BUS=kafka
STORAGE_PROVIDER=s3
SEARCH_PROVIDER=opensearch

# ── Datastores (docker/compose.yml) ──
POSTGRES_URL=postgres://velchat:velchat@localhost:5432/velchat
POSTGRES_MAX_POOL=10
MONGO_URL=mongodb://velchat:velchat@localhost:27017/velchat?authSource=admin
VALKEY_URL=redis://localhost:6379

# ── Kafka (KRaft) — EVENT_BUS=kafka ──
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=velchat
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8080/apis/registry/v2

# ── OpenSearch — SEARCH_PROVIDER=opensearch ──
OPENSEARCH_NODE=http://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=Velchat_dev_1!

# ── MinIO / S3 — STORAGE_PROVIDER=s3 ──
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=velchatadmin
S3_SECRET_KEY=velchatadminsecret
S3_BUCKET=velchat-media

# ── OpenTelemetry (optional locally) ──
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACES_SAMPLER=parentbased_always_on

# ── Auth (dev keypair auto-generated when JWT_PRIVATE_KEY/JWT_PUBLIC_KEY unset) ──
JWT_ISSUER=https://auth.velchat.local
JWT_ACCESS_TTL_SECONDS=900
