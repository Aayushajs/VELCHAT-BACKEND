# ── VelChat — PRODUCTION (free-tier managed: Neon + Atlas + Upstash + Cloudinary + Grafana Cloud) ─
# Set these as PLATFORM env (Render env group / Sealed Secrets / Vault). NEVER commit real values.
# Placeholders only — replace <...>. The app code is identical; only the provider selectors differ.

NODE_ENV=production
LOG_LEVEL=info
# SERVICE_VERSION is auto-stamped from package.json + git short SHA (libs/config). Uncomment to pin (CI).
# SERVICE_VERSION=0.1.0
# PORT is injected by the platform (Render) and mapped to HTTP_PORT automatically by @velchat/config.

# ── Provider selection → managed free tiers ──
EVENT_BUS=redis-streams
STORAGE_PROVIDER=cloudinary
SEARCH_PROVIDER=atlas

# ── Neon (Postgres, serverless) ──
POSTGRES_URL=postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require&channel_binding=require
POSTGRES_MAX_POOL=10

# ── MongoDB Atlas (chat docs; also backs SEARCH_PROVIDER=atlas) ──
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=velchat

# ── Upstash (Redis Streams event bus + cache) — note rediss:// (TLS) ──
VALKEY_URL=rediss://default:<token>@<host>.upstash.io:6379

# ── Cloudinary (media) — STORAGE_PROVIDER=cloudinary ──
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

KAFKA_CLIENT_ID=velchat

# ── Grafana Cloud OTLP (traces/metrics/logs) ──
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-<region>.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64-instanceID:token>

# ── Auth (RS256 keypair from Sealed Secrets; rotate via JWKS) ──
JWT_ISSUER=https://auth.<your-domain>
JWT_ACCESS_TTL_SECONDS=900
# JWT_PRIVATE_KEY / JWT_PUBLIC_KEY — PEM, injected via secrets (never committed)
# WEBAUTHN_RP_ID=<your-domain>   WEBAUTHN_RP_NAME=VelChat   WEBAUTHN_ORIGIN=https://app.<your-domain>
