{
  "name": "velchat",
  "version": "0.1.0",
  "private": true,
  "description": "VelChat — free, OSS, self-hostable WhatsApp + Teams + Slack hybrid (backend monorepo)",
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "setup": "pnpm install && pnpm build",
    "build": "turbo run build",
    "build:libs": "turbo run build --filter=\"./libs/*\"",
    "build:services": "turbo run build --filter=\"./apps/*\"",
    "test": "turbo run test",
    "test:int": "turbo run test:int",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev --parallel",
    "start:all": "node tools/gateway/start-all.mjs",
    "gateway": "node tools/gateway/dev-gateway.mjs",
    "docs": "node tools/print-docs.mjs",
    "dev:api-gateway": "pnpm --filter @velchat/api-gateway dev",
    "dev:realtime": "pnpm --filter @velchat/realtime-gateway dev",
    "dev:auth": "pnpm --filter @velchat/auth-service dev",
    "dev:user": "pnpm --filter @velchat/user-service dev",
    "dev:chat": "pnpm --filter @velchat/chat-service dev",
    "dev:group-channel": "pnpm --filter @velchat/group-channel-service dev",
    "dev:presence": "pnpm --filter @velchat/presence-service dev",
    "dev:notification": "pnpm --filter @velchat/notification-service dev",
    "dev:media": "pnpm --filter @velchat/media-service dev",
    "dev:search": "pnpm --filter @velchat/search-service dev",
    "dev:call": "pnpm --filter @velchat/call-service dev",
    "dev:automation": "pnpm --filter @velchat/automation-service dev",
    "dev:ai": "pnpm --filter @velchat/ai-service dev",
    "format": "prettier --write \"**/*.{ts,js,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yaml,yml}\"",
    "proto:gen": "buf generate",
    "db:up": "docker compose -f docker/compose.yml up -d postgres mongo valkey",
    "db:down": "docker compose -f docker/compose.yml down",
    "db:logs": "docker compose -f docker/compose.yml logs -f",
    "db:migrate": "pnpm --filter @velchat/migrations migrate",
    "infra:up": "docker compose -f docker/compose.yml up -d",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "cross-env": "^7.0.3",
    "eslint": "^9.17.0",
    "http-proxy": "^1.18.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1"
  }
}
